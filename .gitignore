# Data directories: commit layout (.gitkeep) only, not data files
data/raw/**
!data/raw/.gitkeep
data/intermediate/**
!data/intermediate/.gitkeep
data/processed/**
!data/processed/.gitkeep

# Dashboard data: copied from data/processed and data/intermediate via
# `make dashboard-data` (a prerequisite of `make app`), not committed
dashboard/data/**
!dashboard/data/.gitkeep

# EDA figs are produced from core pipeline and saved in figures/
# The quarto blog EDA pulls from this single source of truth,
# and does not recreate through in line quarto code
# For the 2 years that the repo will be private this is ok.
# Github actions, when public, would not have access to the figures for rendering the blog
# But for now, this is acceptable and will keep the git history lighter and cleaner
# figures/* 
!figures/mycobiome/.gitkeep
!figures/characteristics/.gitkeep
!figures/diet/.gitkeep

notebooks/*.html

# OS files
.DS_Store

# Editor files
.vscode/

# Quarto site output
# Public demo keeps the rendered stats site committed.
stats/.quarto/
.positai
pipeline_diagram.html
